# Navegação e Atalhos
alias dev="pnpm run dev"
alias build="pnpm run build"
alias pi="pnpm install"

# Git
alias gs="git status"
alias gp="git push"
alias gcm="git commit -m"
alias gco="git checkout"
alias gcob="git checkout -B"

# Docker
alias dcu="docker-compose up -d"
alias dcd="docker-compose down"